# Copinance OS Environment Configuration
# Copy this file to .env and update with your values.
# Pydantic Settings use prefix COPINANCEOS_ (see src/copinance_os/infra/config/settings.py).
# LLM vars are read directly from the environment (see src/copinance_os/ai/llm/config_loader.py).

# =============================================================================
# Application
# =============================================================================
COPINANCEOS_APP_NAME="Copinance OS"
# development | staging | production
COPINANCEOS_ENVIRONMENT=development

# =============================================================================
# Analysis execution
# =============================================================================
# Default pipeline timeout in seconds
COPINANCEOS_DEFAULT_ANALYSIS_TIMEOUT=300
# Enable question-driven (agent) AI analysis
COPINANCEOS_ENABLE_AGENT_ANALYSIS=true

# =============================================================================
# Storage
# =============================================================================
# Backend: file (persistent) or memory (ephemeral, for testing)
COPINANCEOS_STORAGE_TYPE=file
# Persistence root; empty or "." is normalized to .copinance (nothing at project root).
COPINANCEOS_STORAGE_PATH=.copinance

# =============================================================================
# Cache
# =============================================================================
# Tool results and agent prompt cache (default: true). Set false if you inject your own cache.
COPINANCEOS_CACHE_ENABLED=true

# =============================================================================
# Logging
# =============================================================================
# DEBUG | INFO | WARNING | ERROR | CRITICAL
COPINANCEOS_LOG_LEVEL=INFO
# json (production) | console (development)
COPINANCEOS_LOG_FORMAT=console

# =============================================================================
# LLM (question-driven analysis) — not part of Settings; read via getenv
# =============================================================================
# Options: gemini | ollama | openai
COPINANCEOS_LLM_PROVIDER=gemini
COPINANCEOS_LLM_TEMPERATURE=0.7
# Omit empty; set to integer when needed
COPINANCEOS_LLM_MAX_TOKENS=

# Optional per-execution-type mapping: execution_type:provider_name,...
# Example: instrument_analysis:ollama,question_driven_analysis:gemini
COPINANCEOS_LLM_PROVIDERS=

# ---- Gemini (Google) ----
# API key: https://aistudio.google.com
# If COPINANCEOS_GEMINI_MODEL is unset, default in code is gemini-1.5-pro
COPINANCEOS_GEMINI_API_KEY=
COPINANCEOS_GEMINI_MODEL=gemini-2.5-flash

# ---- OpenAI ----
# API key: https://platform.openai.com/api-keys
COPINANCEOS_OPENAI_API_KEY=
COPINANCEOS_OPENAI_MODEL=gpt-4
# Optional; omit for provider default (https://api.openai.com/v1)
# COPINANCEOS_OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Ollama (local) ----
# https://ollama.ai — pip install -e ".[ollama]"
COPINANCEOS_OLLAMA_BASE_URL=http://localhost:11434
COPINANCEOS_OLLAMA_MODEL=llama2

# =============================================================================
# FRED (macro time series) — optional for macro tools; COPINANCEOS_FRED_API_KEY required to fetch
# =============================================================================
# API key: https://fred.stlouisfed.org/docs/api/api_key.html
COPINANCEOS_FRED_API_KEY=
COPINANCEOS_FRED_BASE_URL=https://api.stlouisfed.org/fred
COPINANCEOS_FRED_RATE_LIMIT_DELAY=0.1
COPINANCEOS_FRED_TIMEOUT_SECONDS=30.0

# =============================================================================
# SEC EDGAR — identity required for programmatic access (name + email)
# =============================================================================
# Prefer this app-prefixed var, or set EDGAR_IDENTITY (edgartools convention; checked first).
COPINANCEOS_EDGAR_IDENTITY="Your Name your.email@example.com"
# EDGAR_IDENTITY="Your Name your.email@example.com"

# =============================================================================
# Options — analytic BSM Greeks from chain metadata (QuantLib)
# =============================================================================
# Omit these keys entirely unless overriding; empty values are invalid for floats.
# Annualized risk-free rate (e.g. 0.045); omit for built-in default.
# COPINANCEOS_OPTION_GREEKS_RISK_FREE_RATE=0.045
# Default continuous dividend yield when chain has none (omit means 0).
# COPINANCEOS_OPTION_GREEKS_DIVIDEND_YIELD_DEFAULT=0.0
