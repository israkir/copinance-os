# Copinance OS Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Storage
# =============================================================================
# Backend: file (persistent) or memory (ephemeral, for testing)
COPINANCEOS_STORAGE_TYPE=file
# All persisted data (entity data, cache, results, state) goes under this root. Use .copinance (default); empty or "." is normalized to .copinance so nothing is created at project root.
COPINANCEOS_STORAGE_PATH=.copinance

# =============================================================================
# Cache
# =============================================================================
# Enable built-in cache for tool results and agent prompts (default: true).
# Set to false to disable, or use your own cache via get_container(cache_manager=...)
COPINANCEOS_CACHE_ENABLED=true

# =============================================================================
# Logging
# =============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
COPINANCEOS_LOG_LEVEL=INFO
# Format: json (production) or console (development)
COPINANCEOS_LOG_FORMAT=console

# =============================================================================
# LLM Provider (for question-driven analysis)
# =============================================================================
# Options: gemini, ollama, openai, anthropic
COPINANCEOS_LLM_PROVIDER=gemini
COPINANCEOS_LLM_TEMPERATURE=0.7
COPINANCEOS_LLM_MAX_TOKENS=

# Per-execution-type provider mapping (optional): execution_type:provider_name,...
# Example: instrument_analysis:ollama,question_driven_analysis:gemini
COPINANCEOS_LLM_PROVIDERS=

# ---- Gemini (Google) ----
# API key: https://aistudio.google.com
COPINANCEOS_GEMINI_API_KEY=
COPINANCEOS_GEMINI_MODEL=gemini-2.5-flash

# ---- OpenAI ----
# API key: https://platform.openai.com/api-keys
COPINANCEOS_OPENAI_API_KEY=
COPINANCEOS_OPENAI_MODEL=gpt-4
# COPINANCEOS_OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic ----
# API key: https://console.anthropic.com/
COPINANCEOS_ANTHROPIC_API_KEY=
COPINANCEOS_ANTHROPIC_MODEL=claude-3-opus-20240229

# ---- Ollama (local) ----
# Install: https://ollama.ai; then: ollama pull llama2
# Install with Ollama support: pip install -e ".[ollama]"
COPINANCEOS_OLLAMA_BASE_URL=http://localhost:11434
COPINANCEOS_OLLAMA_MODEL=llama2

# =============================================================================
# Macro data (FRED) – optional, for macro indicators in agent tools
# =============================================================================
# API key: https://fred.stlouisfed.org/docs/api/api_key.html
COPINANCEOS_FRED_API_KEY=
